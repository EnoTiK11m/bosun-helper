{
  "manifest_version": 3,
  "name": "Bosun Helper",
  "version": "1.0.0",
  "description": "Браузерный плагин для дашборда Bosun, который снижает визуальный шум и ускоряет работу дежурного с алертами",
  "permissions": [
    "storage"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "bosun_notification_alert_chime.wav",
        "bosun_notification_soft_chime.wav"
      ],
      "matches": [
        "*://bosun.example.com/*",
        "*://bosun-test.example.com/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "*://bosun.example.com/*",
        "*://bosun-test.example.com/*"
      ],
      "js": [
        "shared-utils.js",
        "diagnostics.js",
        "sound.js",
        "alerts-data.js",
        "needack-baseline.js",
        "needack-severity.js",
        "page-utils.js",
        "styles.js",
        "activity.js",
        "content.js"
      ],
      "run_at": "document_end"
    }
  ]
}
